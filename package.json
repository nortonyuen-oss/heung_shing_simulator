{
  "name": "city-builder",
  "version": "3.3.0",
  "description": "SimCity 2000-style city builder with local SQLite save system",
  "author": "The City of Heung Shing",
  "repository": {
    "type": "git",
    "url": "https://github.com/nortonyuen-oss/heung_shing_simulator.git"
  },
  "main": "electron-main.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "start": "node server.js",
    "dev": "node server.js",
    "electron:dev": "node scripts/run-electron.js",
    "rebuild:electron": "electron-builder install-app-deps",
    "prepare:release-assets": "node scripts/prepare-release-assets.js",
    "verify:release-assets": "node scripts/verify-release-assets.js",
    "dist": "npm run prepare:release-assets && npm run verify:release-assets && electron-builder",
    "dist:mac": "npm run prepare:release-assets && npm run verify:release-assets && electron-builder --mac",
    "dist:win": "npm run prepare:release-assets && npm run verify:release-assets && electron-builder --win",
    "generate:icons": "node scripts/generate-icons.js",
    "migrate:pg-to-sqlite": "node scripts/migrate-pg-to-sqlite.js",
    "optimize:assets": "node scripts/optimize-model-assets.js",
    "defringe:assets": "node scripts/defringe-model-assets.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^39.8.10",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.heungshing.citybuilder",
    "productName": "The City of Heung Shing",
    "publish": [
      {
        "provider": "github",
        "owner": "nortonyuen-oss",
        "repo": "heung_shing_simulator"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "UI/news/**/*.webp",
      "!UI/news/**/*.png",
      "!release/**",
      "!docs/**",
      "!test/**",
      "!test-results/**",
      "!scripts/**",
      "!Models/**",
      "!.data/**",
      "!.git/**",
      "!.vscode/**",
      "!.claude/**",
      "!.venv/**",
      "!.DS_Store",
      "!**/.DS_Store",
      "!**/process_log.csv",
      "!**/settings.json",
      {
        "from": ".data/package-assets/Models",
        "to": "Models",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.games",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
